# Django core settings
# Required: set a strong, unique secret key for each environment.
DJANGO_SECRET_KEY=change-this-to-a-long-random-secret

# true for local development, false for production
DJANGO_DEBUG=true

# Comma-separated hosts, no spaces needed
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CORS settings
# Keep false in production unless you know what you are doing.
DJANGO_CORS_ALLOW_ALL=false

# Comma-separated origins (include scheme and port)
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
